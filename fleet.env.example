# DCM Fleet Environment Configuration
# Copy this file to /etc/commander/fleet/fleet.env and customize as needed

# ==============================================================================
# ROS2 Configuration
# ==============================================================================

# ROS2 middleware implementation (CycloneDDS for fleet communication)
RMW_IMPLEMENTATION=rmw_cyclonedds_cpp

# ROS2 distribution name
ROS_DISTRO=kilted

# ROS domain ID (default 0, change if running multiple ROS2 networks)
ROS_DOMAIN_ID=0

# ==============================================================================
# DCM Paths
# ==============================================================================

# Root directory for DCM application
DCM_DIR=/home/developer/ros2_ws/src/commander-fleet/dcm-control

# Configuration directory
CONFIG_DIR=/etc/commander/fleet

# Log directory
LOG_DIR=/var/log/commander/fleet

# ==============================================================================
# CycloneDDS Configuration
# ==============================================================================

# CycloneDDS configuration file
CYCLONEDDS_URI=file:///home/developer/cyclonedds.xml

# ==============================================================================
# Application Configuration
# ==============================================================================

# Web interface port
APP_PORT=8090

# Node environment (development, production)
NODE_ENV=production

# Enable debug logging (true/false)
DEBUG=false

# ==============================================================================
# Hardware Configuration
# ==============================================================================

# CAN interface for hardware communication
CAN_INTERFACE=can0

# CAN bitrate (1000000 = 1Mbps)
CAN_BITRATE=1000000

# ==============================================================================
# Kiosk Configuration
# ==============================================================================

# URL for kiosk display
KIOSK_URL=http://localhost:8090

# Kiosk user (for auto-login)
KIOSK_USER=developer
