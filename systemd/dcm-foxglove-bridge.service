[Unit]
Description=DCM Fleet ROS2 Foxglove WebSocket Bridge
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=developer
EnvironmentFile=/home/developer/ros2_ws/src/commander-fleet/dcm-control/config/fleet.env
ExecStart=/bin/bash -c 'source /opt/ros/kilted/setup.bash && source /home/developer/ros2_ws/install/setup.bash && export RMW_IMPLEMENTATION && ros2 launch /opt/commander/fleet/deployment/systemd/dcm-foxglove-bridge.launch.py'
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
